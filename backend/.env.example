# Server
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Database (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/db?sslmode=require

# Redis (Upstash — use wire protocol URL with TLS, NOT the REST URL)
# Format: rediss://default:<token>@<host>.upstash.io:6379
# Note: rediss:// (double-s) enables TLS. redis:// without TLS will fail.
REDIS_URL=rediss://default:your_token_here@your-host.upstash.io:6379

# Session
SESSION_SECRET=change_this_to_a_long_random_string

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://bind-one-zeta.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# In dev: http://localhost:3001/api/auth/google/callback
# In prod (Vercel): https://bind-one-zeta.vercel.app/api/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Token Encryption (32 bytes hex = 64 chars)
ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

# Logging
LOG_LEVEL=debug
